APP_NAME=sms-gateway
APP_ENV=local
APP_DEBUG=true
API_PREFIX=/api
LOG_LEVEL=INFO
LOG_JSON=false

COST_PER_MESSAGE=1
COST_PER_EXPRESS_MESSAGE=1
MAX_MESSAGES_PER_BATCH=100

# Local host defaults. Docker Compose overrides these to use service names.
DATABASE_URL=postgresql+psycopg://sms_gateway:sms_gateway@localhost:5432/sms_gateway
DB_CREATE_ALL=true
DB_PRE_START_RETRIES=30
DB_PRE_START_INTERVAL_SECONDS=1

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

POSTGRES_DB=sms_gateway
POSTGRES_USER=sms_gateway
POSTGRES_PASSWORD=sms_gateway

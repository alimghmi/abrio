APP_NAME=abrio-gateway
APP_ENV=local
APP_DEBUG=false
API_PREFIX=/api
LOG_LEVEL=INFO
LOG_JSON=false

COST_PER_MESSAGE=1.00
COST_PER_EXPRESS_MESSAGE=1.00
MAX_MESSAGES_PER_BATCH=100

SMS_PROVIDER=dummy
SMS_MOCK_FAIL_RATE=0.0
MAX_DELIVERY_ATTEMPTS=5
EXPRESS_TTL_SECONDS=120

RATE_LIMIT_ENABLED=false
RATE_LIMIT_FAIL_OPEN=true
RATE_LIMIT_KEY_PREFIX=sms_gateway:rate_limit
RATE_LIMIT_REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_NORMAL_MESSAGES_PER_MINUTE=12000
RATE_LIMIT_NORMAL_MESSAGES_BURST=2000
RATE_LIMIT_EXPRESS_MESSAGES_PER_MINUTE=1200
RATE_LIMIT_EXPRESS_MESSAGES_BURST=200
RATE_LIMIT_BATCH_REQUESTS_PER_MINUTE=120
RATE_LIMIT_BATCH_REQUESTS_BURST=20
RATE_LIMIT_MESSAGE_STATUS_PER_MINUTE=2400
RATE_LIMIT_MESSAGE_STATUS_BURST=400
RATE_LIMIT_MESSAGE_REPORTS_PER_MINUTE=240
RATE_LIMIT_MESSAGE_REPORTS_BURST=40
RATE_LIMIT_USER_READS_PER_MINUTE=600
RATE_LIMIT_USER_READS_BURST=100
RATE_LIMIT_USER_WRITES_PER_MINUTE=60
RATE_LIMIT_USER_WRITES_BURST=15
RATE_LIMIT_USER_CREATES_PER_MINUTE=20
RATE_LIMIT_USER_CREATES_BURST=5
RATE_LIMIT_PRICING_PER_MINUTE=240
RATE_LIMIT_PRICING_BURST=40
RATE_LIMIT_GLOBAL_NORMAL_MESSAGES_PER_MINUTE=180000
RATE_LIMIT_GLOBAL_NORMAL_MESSAGES_BURST=20000
RATE_LIMIT_GLOBAL_EXPRESS_MESSAGES_PER_MINUTE=45000
RATE_LIMIT_GLOBAL_EXPRESS_MESSAGES_BURST=5000
RATE_LIMIT_GLOBAL_BATCH_REQUESTS_PER_MINUTE=3000
RATE_LIMIT_GLOBAL_BATCH_REQUESTS_BURST=300
RATE_LIMIT_GLOBAL_MESSAGE_STATUS_PER_MINUTE=120000
RATE_LIMIT_GLOBAL_MESSAGE_STATUS_BURST=12000
RATE_LIMIT_GLOBAL_MESSAGE_REPORTS_PER_MINUTE=12000
RATE_LIMIT_GLOBAL_MESSAGE_REPORTS_BURST=1200
RATE_LIMIT_GLOBAL_USER_READS_PER_MINUTE=30000
RATE_LIMIT_GLOBAL_USER_READS_BURST=3000
RATE_LIMIT_GLOBAL_USER_WRITES_PER_MINUTE=6000
RATE_LIMIT_GLOBAL_USER_WRITES_BURST=600
RATE_LIMIT_GLOBAL_USER_CREATES_PER_MINUTE=1200
RATE_LIMIT_GLOBAL_USER_CREATES_BURST=120
RATE_LIMIT_GLOBAL_PRICING_PER_MINUTE=12000
RATE_LIMIT_GLOBAL_PRICING_BURST=1200
RATE_LIMIT_SYSTEM_REQUESTS_PER_MINUTE=300000
RATE_LIMIT_SYSTEM_REQUESTS_BURST=30000
RATE_LIMIT_SYSTEM_MESSAGES_PER_MINUTE=225000
RATE_LIMIT_SYSTEM_MESSAGES_BURST=25000

DATABASE_URL=postgresql+psycopg://sms_gateway:sms_gateway@localhost:5432/sms_gateway
DB_CREATE_ALL=true
DB_PRE_START_RETRIES=30
DB_PRE_START_INTERVAL_SECONDS=1.0

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

# Docker Compose service URLs. These are used only by docker-compose.yml.
DOCKER_DATABASE_URL=postgresql+psycopg://sms_gateway:sms_gateway@postgres:5432/sms_gateway
DOCKER_REDIS_URL=redis://redis:6379/0
DOCKER_CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
DOCKER_CELERY_RESULT_BACKEND=redis://redis:6379/1

POSTGRES_DB=sms_gateway
POSTGRES_USER=sms_gateway
POSTGRES_PASSWORD=sms_gateway
